# ─────────────────────────────────────────────────────
# .env.local — Copy this file and fill in your values.
# NEVER commit the filled version to git.
# Add these same keys in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────

# ── RAZORPAY ─────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Get from: https://dashboard.razorpay.com → Settings → Webhooks
# Set when creating your webhook (you choose this secret yourself)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── GOOGLE SHEETS ─────────────────────────────────────
# The ID is in your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/[THIS_PART]/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# From your Google Cloud Service Account JSON file:
# (see SETUP.md for how to create this)
GOOGLE_SERVICE_ACCOUNT_EMAIL=workshop-bot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----\n"
